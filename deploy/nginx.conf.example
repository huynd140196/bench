# Nginx reverse proxy for the Bench app (Express serving the built client on one port,
# in production — see server/src/index.js). Not applied automatically; see DEPLOY.md.
#
# Copy to /etc/nginx/sites-available/bench, edit server_name, symlink into
# sites-enabled, `sudo nginx -t`, then `sudo systemctl reload nginx`.

server {
    listen 80;
    listen [::]:80;
    server_name your-domain.example.com;

    location / {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

